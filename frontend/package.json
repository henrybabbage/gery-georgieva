{
  "name": "frontend",
  "private": true,
  "scripts": {
    "prebuild": "sanity typegen generate",
    "build": "next build",
    "predev": "npm run sanity:typegen",
    "dev": "next dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "sanity:typegen": "cd ../studio && sanity schema extract --enforce-required-fields --path ../sanity.schema.json && cd ../frontend && sanity typegen generate",
    "start": "next start",
    "type-check": "tsc --noEmit"
  },
  "prettier": "@sanity/prettier-config",
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@paper-design/shaders-react": "^0.0.76",
    "@sanity/client": "^7.20.0",
    "@sanity/image-url": "^2.1.1",
    "@sanity/uuid": "^3.0.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@vercel/speed-insights": "^1.3.1",
    "autoprefixer": "^10.4.27",
    "cambio": "^1.1.5",
    "date-fns": "^4.1.0",
    "dialkit": "^1.2.0",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "lucide-react": "^1.14.0",
    "media-chrome": "4.19.0",
    "motion": "^12.38.0",
    "next": "^16.2.4",
    "next-sanity": "^12.3.0",
    "postcss": "^8.5.8",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sanity": "^5.23.0",
    "sanity-image": "^1.1.0",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.2.2",
    "three": "^0.183.0",
    "tweakpane": "^4.0.5",
    "vimeo-video-element": "1.7.1"
  },
  "devDependencies": {
    "@sanity/prettier-config": "^3.0.0",
    "@types/node": "^22.19.17",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/three": "^0.183.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "typescript": "5.9.3"
  }
}
